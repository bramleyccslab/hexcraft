bc[[task]]<-matrix(NA, length(solutions_sorted_condition[[1]][[task]]),length(solutions_sorted_condition[[2]][[task]]))
# WITHIN CONDITION
for (i in 1:length(solutions_sorted_condition[[1]][[task]]))
{
